# .gitattributes — per-path git attributes for the Educore repo.
# See ADR-016-EngineGraph.md and AGENTS.md § "Engine Graph (graphify)".

# -----------------------------------------------------------------------------
# Engine knowledge graph (graphify)
# -----------------------------------------------------------------------------
# graph.json uses the graphify-union merge driver so two parallel
# commits that both rebuild the graph don't produce conflict markers.
# The driver calls `graphify merge-graphs` (which union-merges the
# nodes/edges/hyperedges from %O, %A, %B into a single graph).
# See `merge.graphify-union.*` in `.git/config`.
graphify-out/graph.json merge=graphify-union
