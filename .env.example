# =============================================================================
# SMSengine — `.env.example` (TRACKED TEMPLATE)
# =============================================================================
# NOTE: SMSengine is a library. It does not read environment variables.
# This file documents the configuration surface that consumer
# applications are expected to set when wiring the engine. It is
# tracked in git as a reference. Copy it to `.env` (gitignored) and
# fill in real values for your local services.
#
#     cp .env.example .env
#
# Consumers only need the sections for the ports they actually wire.
# A consumer that uses MySQL + JWT + SMTP does not need Stripe, NATS,
# or any of the other sections — leave them blank or delete them.
#
# Every variable is documented in:
#   - docs/library-docs.md        (Engine::builder, common workflow)
#   - docs/ports/<port>.md        (per-port contract and config)
#
# NEVER commit real credentials. The values below are placeholders for
# a local dev stack (docker-compose, MinIO, MailHog, local MySQL).
# Generate secrets with `openssl rand -base64 48`.
#
# Sections:
#   1. Runtime environment
#   2. Logging & observability
#   3. Storage (database)               -> docs/ports/storage.md
#   4. Authentication (JWT, OAuth2)     -> docs/ports/authentication.md
#   5. Notification (SMTP, SMS, FCM)    -> docs/ports/notifications.md
#   6. Payment (Stripe, PayPal, cash)   -> docs/ports/payments.md
#   7. File storage (S3, local)         -> docs/ports/file-storage.md
#   8. Event bus (in-process, NATS, ..) -> docs/ports/event-bus.md
#   9. Integrations (webhooks, Twilio)  -> docs/ports/integrations.md
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Runtime environment
# -----------------------------------------------------------------------------
SMSENGINE_ENV=development          # development | staging | production
SMSENGINE_INSTANCE_ID=local-dev-01
SMSENGINE_BIND=0.0.0.0:8080        # for consumer HTTP frontends

# -----------------------------------------------------------------------------
# 2. Logging & observability
# -----------------------------------------------------------------------------
RUST_LOG=info,smsengine=debug,sqlx=warn
RUST_BACKTRACE=1
SMSENGINE_LOG_FORMAT=pretty         # pretty | json
SMSENGINE_LOG_FILE=                 # empty = stdout; path for file output
SMSENGINE_TRACING_SAMPLE_RATE=1.0   # 0.0..1.0, fraction of traces sampled

# -----------------------------------------------------------------------------
# 3. Storage (database)
# Reference: docs/ports/storage.md
# Shipped adapters: postgres, mysql, sqlite (deferred: mongodb, surrealdb)
# -----------------------------------------------------------------------------
SMSENGINE_STORAGE_ADAPTER=mysql     # postgres | mysql | sqlite
SMSENGINE_STORAGE_MAX_CONNECTIONS=20
SMSENGINE_STORAGE_MIN_CONNECTIONS=2
SMSENGINE_STORAGE_ACQUIRE_TIMEOUT_SECS=5
SMSENGINE_STORAGE_STATEMENT_CACHE_CAPACITY=128

# Primary connection URL. Format depends on the adapter:
#   postgres://smsengine:smsengine@127.0.0.1:5432/smsengine
#   mysql://smsengine:smsengine@127.0.0.1:3306/smsengine
#   sqlite://./var/data/smsengine.db?mode=rwc
DATABASE_URL="mysql://smsengine:smsengine@127.0.0.1:3306/smsengine"

# Read replica (optional, used for read-only queries that tolerate lag)
# DATABASE_URL_READ="mysql://smsengine:smsengine@127.0.0.1:3307/smsengine"

# -----------------------------------------------------------------------------
# 4. Authentication (JWT, OAuth2, MFA)
# Reference: docs/ports/authentication.md
# -----------------------------------------------------------------------------
# JWT — required for JwtAuthProvider. Use 32+ random bytes.
JWT_SECRET=replace-me-with-a-32-byte-random-secret-from-openssl-rand-base64-48
JWT_ISSUER=smsengine.local
JWT_AUDIENCE=smsengine
JWT_ACCESS_TTL_SECS=3600
JWT_REFRESH_TTL_SECS=604800

# Argon2id parameters for LocalPasswordAuthProvider
ARGON2_MEMORY_KIB=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# OAuth2 (optional; leave blank to disable the provider)
OAUTH2_GOOGLE_CLIENT_ID=
OAUTH2_GOOGLE_CLIENT_SECRET=
OAUTH2_GOOGLE_REDIRECT_URI=http://localhost:8080/auth/oauth/google/callback

# SAML (optional)
SAML_IDP_METADATA_URL=
SAML_SP_ENTITY_ID=smsengine.local
SAML_SP_ACS_URL=http://localhost:8080/auth/saml/acs

# MFA — TOTP issuer label
MFA_ISSUER_LABEL=SMSengine

# -----------------------------------------------------------------------------
# 5. Notification (SMTP, SMS, push)
# Reference: docs/ports/notifications.md
# -----------------------------------------------------------------------------
NOTIFY_DEFAULT_CHANNEL=email        # email | sms | push | in_app

# Email (SMTP) — works with mailhog/MailSlurper locally
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=no-reply@smsengine.local
SMTP_FROM_NAME=SMSengine
SMTP_TLS=starttls                   # none | starttls | tls

# SMS gateway (provider-agnostic HTTP webhook)
SMS_PROVIDER_URL=
SMS_PROVIDER_API_KEY=
SMS_FROM_NUMBER=

# Push (FCM)
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=

# -----------------------------------------------------------------------------
# 6. Payment (gateway)
# Reference: docs/ports/payments.md
# -----------------------------------------------------------------------------
PAYMENT_DEFAULT_PROVIDER=cash       # cash | cheque | bank | stripe | paypal
PAYMENT_DEFAULT_CURRENCY=USD
PAYMENT_CAPTURE=true                # false for auth-then-capture flows

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2024-06-20

# PayPal (optional)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox                 # sandbox | live

# -----------------------------------------------------------------------------
# 7. File storage (S3-compatible, local)
# Reference: docs/ports/file-storage.md
# -----------------------------------------------------------------------------
FILES_DEFAULT_BACKEND=local         # local | s3 | gcs

# Local filesystem (default for dev)
FILES_LOCAL_ROOT=./var/files
FILES_LOCAL_PUBLIC_URL=http://localhost:8080/files

# S3 / S3-compatible (MinIO, R2, etc.)
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=smsengine
S3_ACCESS_KEY=smsengine
S3_SECRET_KEY=replace-me
S3_PATH_STYLE=true                  # true for MinIO, false for AWS
S3_PRESIGNED_TTL_SECS=900

# GCS (optional)
GCS_BUCKET=
GCS_CREDENTIALS_JSON=

# -----------------------------------------------------------------------------
# 8. Event bus
# Reference: docs/ports/event-bus.md
# -----------------------------------------------------------------------------
EVENT_BUS_BACKEND=in-process         # in-process | nats | redis | kafka
EVENT_BUS_TOPIC_PREFIX=smsengine
EVENT_BUS_RETENTION_DAYS=90

# In-process (default)
EVENT_BUS_INPROCESS_CHANNEL_CAPACITY=1024

# NATS JetStream (optional)
NATS_URL=nats://127.0.0.1:4222
NATS_STREAM=smsengine
NATS_CONSUMER_GROUP=smsengine

# Redis Streams (optional)
REDIS_URL=redis://127.0.0.1:6379
REDIS_STREAM=smsengine
REDIS_CONSUMER_GROUP=smsengine

# Kafka (optional)
KAFKA_BROKERS=127.0.0.1:9092
KAFKA_TOPIC_PREFIX=smsengine
KAFKA_CONSUMER_GROUP=smsengine

# -----------------------------------------------------------------------------
# 9. Integrations
# Reference: docs/ports/integrations.md
# -----------------------------------------------------------------------------
INTEGRATION_HTTP_TIMEOUT_SECS=10
INTEGRATION_RETRY_MAX=5
INTEGRATION_RETRY_BASE_SECS=2
INTEGRATION_RETRY_MAX_SECS=300

# Outbound webhook signing secret (HMAC-SHA256)
WEBHOOK_SIGNING_SECRET=replace-me-with-a-32-byte-random-secret

# Twilio (used via the integration port for advanced SMS flows)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# LMS sync (Google Classroom, Microsoft Teams, Moodle)
LMS_GOOGLE_CLASSROOM_CREDENTIALS_JSON=
LMS_MS_TENANT_ID=
LMS_MS_CLIENT_ID=
LMS_MS_CLIENT_SECRET=
LMS_MOODLE_BASE_URL=
LMS_MOODLE_TOKEN=
